node_modules/

# Re-fetchable source cache and the binary build artifact: not version-controlled.
# (raw zips exceed GitHub's 100MB file limit; the .db is regenerable from raw or export.)
data/raw/
data/incidents_raw/
data/*.db
data/*.db-shm
data/*.db-wal

# Derived data: regenerated from the committed source (data/source/) by
# `npm run export` / CI, so not version-controlled. The published source of truth
# is data/source/ (day-files, market cap, incident HTML).
data/export/

# Assembled deployable site (regenerated by `npm run build:site`).
dist/

*.log
.DS_Store
